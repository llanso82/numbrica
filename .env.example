
# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/numbrica_db
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_NAME=numbrica_db

# Application Configuration
PORT=3000
NODE_ENV=development

# Python Engines Path
PYTHON_ENGINES_PATH=/home/ubuntu/numbrica_engines
PYTHON_TEMPLATES_PATH=/home/ubuntu/numbrica_templates

# API Configuration
CORS_ORIGIN=*

# JWT Configuration
JWT_SECRET=numbrica-secret-key-change-in-production

# SendGrid Configuration (Email Service)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=soporte@numbrica.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001
